{
	"name": "Figure-backend",
	"version": "1.0.0",
	"description": "Figure Backend",
	"main": "dist/index.js",
	"type": "module",
	"scripts": {
		"prestart": "npm run build",
		"start": "node dist/index.js",
		"start:ts": "node dist/index.js",
		"dev": "ts-node-dev --respawn --transpile-only --esm src/index.ts",
		"dev:ts": "ts-node-dev --respawn --transpile-only --esm src/index.ts",
		"build": "tsc",
		"dev:watch": "ts-node-dev --respawn --transpile-only --esm --watch src src/index.ts"
	},
	"dependencies": {
		"bcrypt": "^5.1.1",
		"cookie-parser": "^1.4.6",
		"cors": "^2.8.5",
		"crypto": "^1.0.1",
		"date-fns": "^4.1.0",
		"dotenv": "^16.4.5",
		"express": "^4.19.2",
		"firebase-admin": "^12.5.0",
		"jsonwebtoken": "^9.0.2",
		"moment": "^2.30.1",
		"mongoose": "^8.5.1",
		"multer": "^1.4.5-lts.1",
		"nodemailer": "^6.9.15",
		"otp-generator-random": "^1.0.0",
		"sharp": "^0.33.5",
		"uuid": "^10.0.0"
	},
	"devDependencies": {
		"typescript": "^5.6.3",
		"ts-node-dev": "^2.0.0",
		"@types/node": "^22.9.0",
		"@types/express": "^4.17.21",
		"@types/bcrypt": "^5.0.2",
		"@types/jsonwebtoken": "^9.0.7",
		"@types/cors": "^2.8.17",
		"@types/cookie-parser": "^1.4.7",
		"@types/multer": "^1.4.12",
		"@types/nodemailer": "^6.4.19",
		"nodemon": "^3.1.10"
	}
}
